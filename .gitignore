# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Virtual environment (do NOT commit — Streamlit Cloud builds from requirements.txt)
venv/
.venv/
env/

# Local logs / scratch output
precompute_log.txt
model_3_0_output.txt

# Secrets — the CBBD API key (fetch_cbb_lines.py). NEVER commit it.
.cbbd_key
.env

# Large, reproducible game log (regenerate with: python fetch_data.py 2008 2026)
data/games.csv

# Point-in-time artifacts (regenerate with: python fetch_data.py --pit 2011 2026)
data/games_pit.csv
data/timemachine/

# Raw sportsbook xlsx cache (regenerate with: python fetch_odds.py).
# The parsed data/odds.csv IS committed so the backtest stays reproducible even
# if the upstream archive disappears.
data/odds_cache/

# Strategy-lab derivatives — the app computes these live from data/bet_games.csv,
# so only bet_games.csv is committed (regenerate all with: python betting_strategies.py).
data/betting_strategies_summary.csv
data/betting_strategies_equity.csv
data/betting_strategies_edgesweep.csv

# Me-vs-Machine contest store — user-generated at runtime, mutates on every
# pick/settle. Not committed (the app creates it on first use).
data/contest_picks.csv

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
